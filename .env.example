APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=root

# Docker Compose: Redis service hostname (default 127.0.0.1 only works on host, not inside php/simulation containers)
REDIS_HOST=redis

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# IoT metrics: raw samples in Redis; minute flush writes median aggregates only (disable in tests)
# METRICS_BUFFER_ENABLED=true
# METRICS_BUFFER_REDIS_CONNECTION=default
# METRICS_BUFFER_LIST_KEY=metrics:telemetry_buffer
# METRICS_BUFFER_FLUSH_MAX_RAW_ROWS=250000
# METRICS_BUFFER_MAX_LIST_LEN=50000
# METRICS_BUFFER_WORKER_FLUSH_INTERVAL_SECONDS=60
# METRICS_BUFFER_FLUSH_USE_LOCK=true
# METRICS_BUFFER_FLUSH_LOCK_KEY=metrics:telemetry_buffer_flush
# METRICS_BUFFER_BINARY_TYPE_PATTERN="/_(on|open|running)$/u"
# METRICS_BUFFER_FLUSH_ATOMIC_RENAME=true
# METRICS_BUFFER_QUEUE_CONNECTION=redis
# METRICS_BUFFER_QUEUE=telemetry

VITE_APP_NAME="${APP_NAME}"

# Docker Compose Configuration
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
VITE_PORT=5173

# PHP OPcache Configuration
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_MEMORY_CONSUMPTION=128
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=8
PHP_OPCACHE_MAX_ACCELERATED_FILES=4000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1
PHP_OPCACHE_FAST_SHUTDOWN=1

# IoT simulation: set false when `simulation:worker` runs (Docker) to avoid double ticks with scheduler
SIMULATION_SCHEDULE_TICK_ENABLED=false

# Seconds between full fleet ticks in `php artisan simulation:worker` (and default --interval)
SIMULATION_WORKER_SLEEP_SECONDS=10

# Max time buckets per sensor on the rental monitor charts (evenly spaced across the selected range)
# IOT_MONITOR_CHART_MAX_POINTS=30
# Max DB rows loaded per sensor for bucketing / full-window stats (newest tail if exceeded)
# IOT_MONITOR_CHART_WINDOW_SAMPLES_MAX=10000
# Continuous sensors: median or mean per bucket (binary types always use max/OR)
# IOT_MONITOR_CHART_BUCKET_CONTINUOUS=median
# When the selected time range has no samples, load latest points up to this many days before "to"
# IOT_MONITOR_EXTENDED_LOOKBACK_DAYS=7
# IOT_MONITOR_SNAPSHOT_LATEST_MAX_AGE_SECONDS=120
