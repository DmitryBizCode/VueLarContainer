APP_NAME=LogisticsDmitry
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Mail: log = local only; mailtrap = Mailtrap Email API (verify sending domain in Mailtrap, e.g. sunmere.com)
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
# Use an address on your verified Mailtrap sending domain
MAIL_FROM_ADDRESS="noreply@sunmere.com"
MAIL_FROM_NAME="${APP_NAME}"
# Mailtrap Email API (https://mailtrap.io — API tokens). Do not commit real keys.
MAILTRAP_HOST=send.api.mailtrap.io
MAILTRAP_API_KEY=
# Sandbox only: MAILTRAP_INBOX_ID=
# Comma-separated: new contact form inquiries are copied here
MAIL_CONTACT_ADMIN=
MAIL_SUPPORT_ADDRESS="${MAIL_FROM_ADDRESS}"
MAIL_BRAND_NAME="${APP_NAME}"
# Send email when a user receives an admin/system message (in-app always created)
NOTIFY_NEW_MESSAGE_EMAIL=true
# Email users when any in-app notification is created
NOTIFY_IN_APP_EMAIL=true
# Telegram bot notifications (per-user) when in-app notifications are created
NOTIFY_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
# Public @username of the bot (no @), for profile deep links and docs
TELEGRAM_BOT_USERNAME=
TELEGRAM_HTTP_TIMEOUT=35
TELEGRAM_POLL_INTERVAL_SECONDS=2
#
# The website can show a new design, but Telegram only uses it while telegram:poll runs THIS codebase:
#   Docker:  docker compose build php && docker compose --profile tg up -d telegram
#   Or:      docker compose exec php php artisan telegram:poll
# Command Menu in Telegram is registered automatically on telegram:poll startup (or: php artisan telegram:set-my-commands)
# If true, admin inquiry email only when submitter was logged in (saves Mailtrap quota)
MAIL_INQUIRY_ADMIN_REQUIRES_AUTH_SUBMITTER=false
# Seconds to pause sends after Mailtrap quota/rate-limit errors (mailtrap-sdk transport only)
MAIL_MAILTRAP_QUOTA_CACHE_TTL=3600

# Локальна перевірка листів (Mailpit у docker-compose): UI http://localhost:8025
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=root

# Docker Compose: Redis service hostname (default 127.0.0.1 only works on host, not inside php/simulation containers)
REDIS_HOST=redis

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
# sync = no separate queue worker (listeners + Mail::send run inline). redis/database + worker for production.
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# IoT metrics: raw samples in Redis; minute flush writes median aggregates only (disable in tests)
# METRICS_BUFFER_ENABLED=true
# METRICS_BUFFER_REDIS_CONNECTION=default
# METRICS_BUFFER_LIST_KEY=metrics:telemetry_buffer
# METRICS_BUFFER_FLUSH_MAX_RAW_ROWS=250000
# METRICS_BUFFER_MAX_LIST_LEN=50000
# METRICS_BUFFER_WORKER_FLUSH_INTERVAL_SECONDS=60
# METRICS_BUFFER_FLUSH_USE_LOCK=true
# METRICS_BUFFER_FLUSH_LOCK_KEY=metrics:telemetry_buffer_flush
# METRICS_BUFFER_BINARY_TYPE_PATTERN="/_(on|open|running)$/u"
# METRICS_BUFFER_FLUSH_ATOMIC_RENAME=true
# METRICS_BUFFER_QUEUE_CONNECTION=redis
# METRICS_BUFFER_QUEUE=telemetry

VITE_APP_NAME="${APP_NAME}"

# Docker Compose Configuration
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
VITE_PORT=5173

# PHP OPcache Configuration
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_MEMORY_CONSUMPTION=128
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=8
PHP_OPCACHE_MAX_ACCELERATED_FILES=4000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1
PHP_OPCACHE_FAST_SHUTDOWN=1

# IoT simulation: set false when `simulation:worker` runs (Docker) to avoid double ticks with scheduler
SIMULATION_SCHEDULE_TICK_ENABLED=false

# Seconds between full fleet ticks in `php artisan simulation:worker` (and default --interval)
SIMULATION_WORKER_SLEEP_SECONDS=10

# Max time buckets per sensor on the rental monitor charts (evenly spaced across the selected range)
# IOT_MONITOR_CHART_MAX_POINTS=30
# Max DB rows loaded per sensor for bucketing / full-window stats (newest tail if exceeded)
# IOT_MONITOR_CHART_WINDOW_SAMPLES_MAX=10000
# Continuous sensors: median or mean per bucket (binary types always use max/OR)
# IOT_MONITOR_CHART_BUCKET_CONTINUOUS=median
# When the selected time range has no samples, load latest points up to this many days before "to"
# IOT_MONITOR_EXTENDED_LOOKBACK_DAYS=7
# IOT_MONITOR_SNAPSHOT_LATEST_MAX_AGE_SECONDS=120
